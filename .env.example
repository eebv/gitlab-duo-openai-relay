PORT=8048
# Optional client API key for tools that require an OpenAI API key field.
# Set your own local value; do not commit real shared keys.
GITLAB_RELAY_API_KEY=change-me
GITLAB_GRAPHQL_URL=https://gitlab.com/api/graphql
GITLAB_NAMESPACE_ID=gid://gitlab/Group/YOUR_GROUP_ID
GITLAB_DEFAULT_MODEL_REF=claude_sonnet_4_6_vertex

# Default auth mode: automatically read Cookie/CSRF/User-Agent from the fixed
# Codex Chrome CDP browser at 127.0.0.1:9223. Keep https://gitlab.com/ logged in.
GITLAB_BROWSER_AUTH=1
GITLAB_CHROME_CDP_HOST=127.0.0.1
GITLAB_CHROME_CDP_PORT=9223

# Optional fallback: set both values to bypass browser auth.
# GITLAB_COOKIE=_gitlab_session=...
# GITLAB_CSRF_TOKEN=...

GITLAB_WORKFLOW_TIMEOUT_MS=150000
GITLAB_WORKFLOW_POLL_INTERVAL_MS=3000
GITLAB_WORKFLOW_WS_TIMEOUT_MS=8000
